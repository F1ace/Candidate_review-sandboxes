# Backend
DATABASE_URL=sqlite:///./reviewer.db
ALLOW_ORIGINS=*

# LLM (LM Studio)
# Если backend в docker-compose, на mac/windows используйте host.docker.internal
LM_STUDIO_URL=http://localhost:1234/v1/chat/completions
LM_MODEL=openai/gpt-oss-20b

# Sandboxes
SANDBOX_CODE_URL=http://localhost:8001/run_code
SANDBOX_SQL_URL=http://localhost:8002/run_sql
